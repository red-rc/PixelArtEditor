<Window
    Background="#222222"
    CanResize="False"
    Height="450"
    Icon="/Assets/info-icon.ico"
    Title="Create File"
    Width="400"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d"
    x:Class="PixelArtEditor.Windows.CreateDialogWindow"
    x:DataType="vm:CreateDialogViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:PixelArtEditor.UI"
    xmlns:vm="clr-namespace:PixelArtEditor.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="ShowButtonSpinner" Value="False" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="8192" />
        </Style>
    </Window.Styles>

    <DockPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid
            ColumnDefinitions="*,100"
            DockPanel.Dock="Top"
            Margin="20,50,20,0">
            <ui:Previewer
                Grid.Column="0"
                Margin="30,40,0,0"
                Parameters="{Binding LivePreviewParams}" />

            <Grid
                Grid.Column="1"
                HorizontalAlignment="Right"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    Text="Width" />

                <NumericUpDown
                    Grid.Row="1"
                    Value="{Binding SelectedWidth, Mode=TwoWay}"
                    Width="75" />

                <TextBlock
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Text="Height" />

                <NumericUpDown
                    Grid.Row="3"
                    Value="{Binding SelectedHeight, Mode=TwoWay}"
                    Width="75" />

                <TextBlock
                    Grid.Row="4"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Text="Format" />

                <ComboBox
                    Grid.Row="5"
                    HorizontalAlignment="Center"
                    ItemsSource="{Binding FormatOptions}"
                    SelectedItem="{Binding SelectedFormat, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="14" Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock
                    Grid.Row="6"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Text="Background &#x0a;Color" />

                <ColorPicker
                    Color="{Binding SelectedColor, Mode=TwoWay}"
                    Grid.Row="7"
                    Height="35"
                    HorizontalAlignment="Center"
                    Width="100" />
            </Grid>
        </Grid>
        <Grid
            Background="#1b1b1b"
            ColumnDefinitions="*,Auto,Auto"
            DockPanel.Dock="Bottom"
            Height="100"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom">
            <Button
                Classes="BorderButton"
                Command="{Binding CancelCommand}"
                Content="Cancel"
                FontSize="20"
                Grid.Column="0"
                HorizontalAlignment="Right"
                Margin="0,25,10,25"
                Padding="30,0,30,0"
                VerticalAlignment="Stretch" />
            <Button
                Classes="BlueButton"
                Command="{Binding ConfirmCommand}"
                Content="Create"
                FontSize="20"
                Grid.Column="1"
                HorizontalAlignment="Right"
                Margin="0,25,10,25"
                Padding="30,0,30,0"
                VerticalAlignment="Stretch" />
        </Grid>
    </DockPanel>
</Window>