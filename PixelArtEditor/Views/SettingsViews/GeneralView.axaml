<UserControl
    x:Class="PixelArtEditor.Views.SettingsViews.GeneralView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:other="clr-namespace:PixelArtEditor.Other"
    xmlns:vm="clr-namespace:PixelArtEditor.ViewModels"
    d:DesignHeight="350"
    d:DesignWidth="450"
    x:DataType="vm:SettingsDialogViewModel"
    Background="{DynamicResource SecondaryBackgroundColor}"
    mc:Ignorable="d">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.Heading">
            <Setter Property="FontSize" Value="20" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="ShowButtonSpinner" Value="False" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="8192" />
            <Setter Property="Height" Value="30" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0,10,0" />
        </Style>
    </UserControl.Styles>
    <StackPanel Orientation="Vertical" Spacing="5">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{DynamicResource GenViewLanguage}" />
            <ComboBox
                Width="200"
                ItemsSource="{Binding LanguagePairs}"
                SelectedItem="{Binding Language, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Value}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <TextBlock
            Margin="0,10,0,0"
            Classes="Heading"
            Text="{DynamicResource GenViewGrid}" />
        <Separator
            Height="1"
            Margin="0.5"
            Background="Gray"
            Foreground="{DynamicResource ForegroundColor}" />
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{DynamicResource GenViewGridMaxSize}" />
            <NumericUpDown
                Width="50"
                Maximum="8192"
                Minimum="0"
                Value="{Binding GridMaxSize}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{DynamicResource GenViewGridColor}" />
            <ColorPicker Width="100" Color="{Binding GridColor, Mode=TwoWay}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{DynamicResource GenViewEnableGrid}" />
            <CheckBox IsChecked="{Binding EnableGrid}" />
        </StackPanel>
        <TextBlock
            Margin="0,10,0,0"
            Classes="Heading"
            Text="{DynamicResource GenViewAutosave}" />
        <Separator
            Height="1"
            Margin="0.5"
            Background="Gray"
            Foreground="{DynamicResource ForegroundColor}" />
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{DynamicResource GenViewEnableAutosave}" />
            <CheckBox IsChecked="{Binding EnableAutosave}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{DynamicResource GenViewAutosaveEvery}" />
            <NumericUpDown
                Width="50"
                IsEnabled="{Binding EnableAutosave}"
                Maximum="600"
                Minimum="10"
                Value="{Binding AutosaveFrequency}" />
            <TextBlock Text="{DynamicResource GenViewSeconds}" />
        </StackPanel>
    </StackPanel>
</UserControl>
