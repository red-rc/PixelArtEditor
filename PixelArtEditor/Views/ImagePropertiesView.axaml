<UserControl
    x:Class="PixelArtEditor.Views.ImagePropertiesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:PixelArtEditor.UI"
    xmlns:vm="clr-namespace:PixelArtEditor.ViewModels"
    Width="100"
    Height="185"
    d:DesignHeight="185"
    d:DesignWidth="100"
    x:DataType="vm:ImagePropertiesViewModel"
    Background="{DynamicResource BackgroundColor}"
    mc:Ignorable="d">
   <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value="sans-serif" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="ShowButtonSpinner" Value="False" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="8192" />
            <Setter Property="Height" Value="30" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0,10,0" />
        </Style>
    </UserControl.Styles>

    <DockPanel
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="{DynamicResource SecondaryBackgroundColor}">
        <Grid
            DockPanel.Dock="Top">
            <Grid
                HorizontalAlignment="Right"
                RowDefinitions="Auto,Auto,Auto">
                <StackPanel Grid.Row="0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Text="DPI" />
                    <NumericUpDown
                        Width="75"
                        Value="{Binding SelectedDPI, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Text="Pixel Format" />
                    <ComboBox
                        Width="100"
                        Padding="8,0,0,0"
                        HorizontalAlignment="Center"
                        ItemsSource="{Binding PixelFormatOptions}"
                        SelectedItem="{Binding SelectedPixelFormat, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="14" Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        Text="Alpha Format" />
                    <ComboBox
                        Width="100"
                        Padding="8,0,0,0"
                        HorizontalAlignment="Center"
                        ItemsSource="{Binding AlphaFormatOptions}"
                        SelectedItem="{Binding SelectedAlphaFormat, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="14" Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
