<Application
    x:Class="PixelArtEditor.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PixelArtEditor"
    xmlns:viewModels="clr-namespace:PixelArtEditor.ViewModels"
    xmlns:views1="clr-namespace:PixelArtEditor.Views">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.DataTemplates>
        <local:ViewLocator />
        <DataTemplate DataType="{x:Type viewModels:StartMenuVM}">
            <views1:StartMenuView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EditorVM}">
            <views1:EditorView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
    </Application.Styles>
</Application>